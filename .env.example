# Google Safe Browsing
# Used by Vite dev proxy in vite.config.ts. Keep this server-side only.
GOOGLE_SAFE_BROWSING_API_KEY=

# Optional frontend override for URL safety checks.
# By default, frontend calls /__dev/safe-browsing in Vite dev
# and /api/safe-browsing/check in production builds.
# VITE_SAFE_BROWSING_PROXY_URL=

# Optional backend origin if you explicitly point the frontend at
# /api/safe-browsing/check during local development.
# SAFE_BROWSING_BACKEND_ORIGIN=http://127.0.0.1:7080

# NIP-50 search relay routing
# Optional absolute relay URL override used by src/lib/nostr/ndk.ts.
# VITE_SEARCH_RELAY_URL=ws://127.0.0.1:3301
# Optional same-origin proxy path used when VITE_SEARCH_RELAY_URL is not set.
# Defaults to /relay.
# VITE_SEARCH_RELAY_PROXY_PATH=/relay
# Vite dev/preview websocket proxy target for the relay path above.
# VITE_SEARCH_RELAY_PROXY_TARGET=ws://127.0.0.1:3301

# Semantic search model tuning
# Embedding model and loading options
# VITE_SEMANTIC_MODEL_ID=Xenova/all-MiniLM-L6-v2
# VITE_SEMANTIC_MODEL_DTYPE=q8
# VITE_SEMANTIC_ALLOW_REMOTE_MODELS=true
# VITE_SEMANTIC_LOCAL_MODEL_PATH=
# Throughput/quality controls
# VITE_SEMANTIC_MAX_BATCH_SIZE=16
# VITE_SEMANTIC_MAX_TEXT_CHARS=2000
# VITE_SEMANTIC_MIN_QUERY_CHARS=3
# Hybrid ranking blend controls (auto-normalized to sum=1)
# VITE_HYBRID_LEXICAL_WEIGHT=0.6
# VITE_HYBRID_SEMANTIC_WEIGHT=0.4
# Increase gamma to emphasize top semantic matches
# VITE_HYBRID_SEMANTIC_GAMMA=1.15
# Minimum semantic score (0..1) for semantic-only candidates
# VITE_HYBRID_MIN_SEMANTIC_ONLY_SCORE=0.45
# Minimum lexical share in final top-k
# VITE_HYBRID_MIN_LEXICAL_SHARE=0.5

# Media moderation model tuning
# VITE_MEDIA_MODERATION_NSFW_MODEL_ID=onnx-community/nsfw_image_detection-ONNX
# VITE_MEDIA_MODERATION_VIOLENCE_MODEL_ID=onnx-community/vit-base-violence-detection-ONNX
# VITE_MEDIA_MODERATION_MODEL_DTYPE=q4
# VITE_MEDIA_MODERATION_ALLOW_REMOTE_MODELS=true
# VITE_MEDIA_MODERATION_LOCAL_MODEL_PATH=
# VITE_MEDIA_MODERATION_PROXY_URL=
# Parallel image moderation workers per request batch
# VITE_MEDIA_MODERATION_CONCURRENCY=2
# Policy thresholds (0..1)
# VITE_MEDIA_MODERATION_NSFW_BLOCK_THRESHOLD=0.96
# VITE_MEDIA_MODERATION_VIOLENCE_BLOCK_THRESHOLD=0.97

# Search intent router (LLM-based query classifier)
# Accuracy-focused default: Gemma 3 270M instruction model in ONNX format.
# For higher instruction-following accuracy, use Gemma 3 1B ONNX-GQA.
# Set VITE_ENABLE_SEARCH_ROUTER=true to enable (disabled by default).
# VITE_ENABLE_SEARCH_ROUTER=false
# Runtime: transformers | webllm | litert
# transformers = @huggingface/transformers ONNX pipeline (default)
# webllm = @mlc-ai/web-llm (MLC model runtime)
# litert = @mediapipe/tasks-genai (LiteRT web models)
# VITE_ROUTER_RUNTIME=transformers
# VITE_ROUTER_MODEL_ID=onnx-community/gemma-3-270m-it-ONNX
# Higher-accuracy option (larger download / slower inference):
# VITE_ROUTER_MODEL_ID=onnx-community/gemma-3-1b-it-ONNX-GQA
# VITE_ROUTER_MODEL_DTYPE=q4
# VITE_ROUTER_ALLOW_REMOTE_MODELS=true
# VITE_ROUTER_LOCAL_MODEL_PATH=
# Timeout for a single classification call (ms). Falls back to 'hybrid' on timeout.
# VITE_ROUTER_TIMEOUT_MS=5000

# Optional WebLLM runtime settings
# VITE_WEBLLM_MODEL_ID=Llama-3.2-1B-Instruct-q4f32_1-MLC

# Optional LiteRT runtime settings (MediaPipe Tasks GenAI)
# VITE_LITERT_MODEL_PATH is used by the Grounded Answer component (SearchAiAnswer).
# VITE_ROUTER_LITERT_MODEL_PATH is used by the Search Intent Router when VITE_ROUTER_RUNTIME=litert.
# Keep these separate: the router needs deterministic 4-token output (temp=0, topK=1),
# while the answer model needs free-form generation (temp=0.2, topK=8, max=320).
# If VITE_ROUTER_LITERT_MODEL_PATH is unset, the router falls back to VITE_LITERT_MODEL_PATH.
# VITE_ROUTER_LITERT_MODEL_PATH=/assets/router-model-int4-Web.litertlm
# VITE_LITERT_MODEL_PATH=/assets/gemma-3n-E2B-it-int4-Web.litertlm
# VITE_LITERT_WASM_ROOT=https://cdn.jsdelivr.net/npm/@mediapipe/tasks-genai@latest/wasm
