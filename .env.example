# Google Safe Browsing
# Used by Vite dev proxy in vite.config.ts. Keep this server-side only.
GOOGLE_SAFE_BROWSING_API_KEY=

# Optional frontend override for URL safety checks.
# By default, frontend calls /__dev/safe-browsing in Vite dev
# and /api/safe-browsing/check in production builds.
# VITE_SAFE_BROWSING_PROXY_URL=

# Optional backend origin if you explicitly point the frontend at
# /api/safe-browsing/check during local development.
# SAFE_BROWSING_BACKEND_ORIGIN=http://127.0.0.1:7080

# DeepL key used by local translation settings fallback.
# Keep in .env.local only. Do not commit real keys.
# VITE_DEEPL_AUTH_KEY=

# ── Feed Discovery Fallback ──────────────────────────────────────────────────
# Optional base URL for Feedsearch-compatible discovery fallback.
# Defaults to https://feedsearch.dev when omitted.
# VITE_FEEDSEARCH_API_BASE=https://feedsearch.dev

# ── Spotify Integration ───────────────────────────────────────────────────────
# Optional Spotify Client ID for the "Connect Spotify" feature.
# When set at build time, users do not need to enter it in Settings.
# Create a free Spotify app at https://developer.spotify.com/dashboard and
# add <your-origin>/settings as a Redirect URI.
# VITE_SPOTIFY_CLIENT_ID=

# ── Apple Music Integration ───────────────────────────────────────────────────
# Optional MusicKit developer token (JWT) for the "Connect Apple Music" feature.
# IMPORTANT: This token is signed with a private MusicKit key from the Apple
# Developer portal. Generate it server-side or offline — NEVER embed the
# private key itself. The token has a maximum validity of 6 months.
# Without this value, Apple Music sign-in is disabled in Settings.
# VITE_APPLE_MUSIC_DEVELOPER_TOKEN=

# ── Semantic search models ────────────────────────────────────────────────────
# Bi-encoder used for embedding-based candidate recall (cached in IndexedDB).
# Must be a feature-extraction model with an ONNX export. Defaults to
# Xenova/all-MiniLM-L6-v2 (~22 MB q8).
# VITE_SEMANTIC_MODEL_ID=Xenova/all-MiniLM-L6-v2
# VITE_SEMANTIC_MODEL_DTYPE=q8

# Cross-encoder used to rerank the top-30 bi-encoder candidates with
# higher-quality joint query-document scoring. Loaded in parallel with the
# bi-encoder during init. Falls back to bi-encoder silently on failure.
# Must be a text-classification model with an ONNX export. Defaults to
# Xenova/ms-marco-MiniLM-L-6-v2 (~22 MB q8).
# VITE_CROSS_ENCODER_MODEL_ID=Xenova/ms-marco-MiniLM-L-6-v2
# VITE_CROSS_ENCODER_ENABLED=true
# Optional model-loading controls:
# VITE_SEMANTIC_ALLOW_REMOTE_MODELS=true
# VITE_SEMANTIC_LOCAL_MODEL_PATH=

# ── Moderation models (text + media) ───────────────────────────────────────
# Text moderation classifier. Defaults to:
#   minuva/MiniLMv2-toxic-jigsaw-onnx
# VITE_MODERATION_MODEL_ID=minuva/MiniLMv2-toxic-jigsaw-onnx
# VITE_MODERATION_MODEL_DTYPE=q8
# VITE_MODERATION_ALLOW_REMOTE_MODELS=true
# VITE_MODERATION_LOCAL_MODEL_PATH=
# Optional LLM referee pass for borderline text moderation decisions:
# Disabled by default for privacy/cost control.
# VITE_AI_MODERATION_ENABLED=false
# When false, AI moderation uses local Gemma only and never sends content to Gemini.
# VITE_AI_MODERATION_ALLOW_REMOTE=false

# Media moderation classifiers. Defaults to:
#   NSFW:     onnx-community/nsfw_image_detection-ONNX
#   Violence: onnx-community/vit-base-violence-detection-ONNX
# VITE_MEDIA_MODERATION_NSFW_MODEL_ID=onnx-community/nsfw_image_detection-ONNX
# VITE_MEDIA_MODERATION_VIOLENCE_MODEL_ID=onnx-community/vit-base-violence-detection-ONNX
# VITE_MEDIA_MODERATION_MODEL_DTYPE=q4
# VITE_MEDIA_MODERATION_ALLOW_REMOTE_MODELS=true
# VITE_MEDIA_MODERATION_LOCAL_MODEL_PATH=
# Optional media fetch proxy (dev/preview helpers can proxy automatically):
# VITE_MEDIA_MODERATION_PROXY_URL=

# ── Strict Local-Only Privacy Profile ───────────────────────────────────────
# Set these in .env.local when you want to block all remote model downloads
# and require explicitly provisioned local model assets.
#
# VITE_SEMANTIC_ALLOW_REMOTE_MODELS=false
# VITE_SEMANTIC_LOCAL_MODEL_PATH=/absolute/path/to/local/hf-models
# VITE_MODERATION_ALLOW_REMOTE_MODELS=false
# VITE_MODERATION_LOCAL_MODEL_PATH=/absolute/path/to/local/hf-models
# VITE_AI_MODERATION_ENABLED=true
# VITE_AI_MODERATION_ALLOW_REMOTE=false
# VITE_MEDIA_MODERATION_ALLOW_REMOTE_MODELS=false
# VITE_MEDIA_MODERATION_LOCAL_MODEL_PATH=/absolute/path/to/local/hf-models

# ── Gemma 4 Local Inference (Google AI Edge / MediaPipe Tasks) ──────────────
# Download one or both .task model files into public/models/:
#   E2B: https://huggingface.co/litert-community/gemma-4-E2B-it-litert-lm/resolve/main/gemma-4-E2B-it-web.task
#   E4B: https://huggingface.co/litert-community/gemma-4-E4B-it-litert-lm/resolve/main/gemma-4-E4B-it-web.task
#
# Then point Vite at the local static asset path. If both are set, the client
# prefers E4B by default and can explicitly select E2B at runtime.
# Requires a WebGPU-capable browser.
# VITE_GEMMA_E2B_MODEL_PATH=/models/gemma-4-E2B-it-web.task
# VITE_GEMMA_E4B_MODEL_PATH=/models/gemma-4-E4B-it-web.task
# Optional runtime tuning:
# VITE_GEMMA_MAX_TOKENS=1024
# VITE_GEMMA_TEMPERATURE=0.8
# VITE_GEMMA_TOP_K=40
# Optional override for WASM runtime location (defaults to local package path)
# VITE_GEMMA_WASM_PATH=https://cdn.jsdelivr.net/npm/@mediapipe/tasks-genai/wasm

# ── Gemini API Translation (Google AI Studio) ───────────────────────────────
# Optional default key/model for the Gemini translation provider in Settings.
# This is convenient for local development, but production apps should prefer a
# backend proxy and keep long-lived API keys server-side.
# VITE_GEMINI_API_KEY=
# VITE_GEMINI_MODEL=gemini-2.5-flash

# ── Tagr Moderation Relay ────────────────────────────────────────────────────
# Override the relay used to fetch Tagr bot moderation labels.
# Defaults to wss://relay.nos.social (the canonical Tagr relay).
#
# In dev, if direct wss:// connections to the relay are blocked or unreliable,
# route through the Vite dev server WebSocket proxy instead:
#   VITE_TAGR_RELAY_URL=ws://localhost:5173/__dev/relay-ws?target=wss://relay.nos.social
# The proxy accepts a ?target= query param (hostname must be in the allowlist).
# VITE_TAGR_RELAY_URL=wss://relay.nos.social
